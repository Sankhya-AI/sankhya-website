{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "headers": [
    {
      "source": "/((?!.*\\..*).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/downloads/:artifact",
      "destination": "/api/downloads/:artifact"
    },
    {
      "source": "/api/web-search",
      "destination": "/api/web?op=search"
    },
    {
      "source": "/api/web-read",
      "destination": "/api/web?op=read"
    },
    {
      "source": "/((?!api/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    { "path": "/api/cron-managed-keys", "schedule": "0 2 * * *" }
  ]
}
